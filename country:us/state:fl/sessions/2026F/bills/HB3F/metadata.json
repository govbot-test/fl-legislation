  "abstracts": [
    {
      "note": "summary",
      "abstract": "Property Tax Administration;  Revises limitations on maximum millage rate that may be levied by certain units of government; conforms provision to changes made by act; authorizes ballot summary of specified proposed amendment or revision of State Constitution to exceed specified word limit; provides for construction of act in pari materia with laws enacted during 2026 Regular Session & 2026 Special Session E of Legislature."
    }
  ],
