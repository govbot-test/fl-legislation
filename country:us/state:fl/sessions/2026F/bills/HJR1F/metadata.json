  "abstracts": [
    {
      "note": "summary",
      "abstract": "Save our Homes from Excessive Property Taxes;  Proposes amendments to State Constitution to revise limitation on annual assessment increases for specified real property, to increase homestead exemption, to provide limitation on use of ad valorem taxes levied by counties & municipalities, & to provide an effective date."
    }
  ],
