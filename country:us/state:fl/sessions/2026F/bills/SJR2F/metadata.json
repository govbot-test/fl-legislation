  "abstracts": [
    {
      "note": "summary",
      "abstract": "Save our Homes from Excessive Property Taxes;  Proposing amendments to the State Constitution to revise the limitation on annual assessment increases for specified real property, to increase the homestead exemption, to provide a limitation on the use of ad valorem taxes levied by counties and municipalities, and to provide an effective date, etc."
    }
  ],
