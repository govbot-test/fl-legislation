  ],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "Property Tax Administration;  Revising the definitions of the terms \"maximum total county ad valorem taxes levied\" and \"maximum total municipal ad valorem taxes levied\" to conform to changes made by the act; revising limitations on the maximum millage rate that may be levied by certain units of government; authorizing the ballot summary of a specified proposed amendment or revision of the State Constitution to exceed a specified word limit, etc."
    }
  ],
